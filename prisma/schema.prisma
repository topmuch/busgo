generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logo            String?
  phone           String?
  email           String?
  address         String?
  country         String    @default("SN")

  // SEO & Branding
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  ogImage         String?
  primaryColor    String    @default("#7C3AED")
  secondaryColor  String    @default("#F43F5E")

  // Subscription
  plan            String    @default("starter")
  subscriptionStatus String @default("trial") // active, suspended, cancelled, trial
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  totalBuses      Int       @default(0)
  monthlyPrice    Int       @default(0) // en FCFA

  // Credentials générés
  adminEmail      String?   @unique // Email de l'admin de la compagnie
  adminPassword   String?   // Hashé, généré automatiquement
  adminPhone      String?

  // Status
  isActive        Boolean   @default(true)
  isSuspended     Boolean   @default(false)
  suspensionReason String?
  suspendedAt     DateTime?
  suspendedBy     String?   // ID du superadmin

  // Stats
  totalRevenue    Int       @default(0) // CA généré pour Bus Go
  lastLoginAt     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users                User[]
  buses                Bus[]
  trajets              Trajet[]
  voiceConfigs         VoiceConfig[]
  subscriptions        Subscription[]
  invoices             Invoice[]
  notificationTemplates NotificationTemplate[]
  auditLogs            AuditLog[]
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  phone           String
  role            String   @default("client")
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  reliabilityScore Float?  @default(100.0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  buses           Bus[]    @relation("Driver")
  billets         Billet[] @relation("Client")
  drivenTrajets   Trajet[] @relation("TrajetDriver")
  auditLogs       AuditLog[]
}

// Role values: superadmin, admin, agent, client

model Bus {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  number    String
  capacity  Int
  driverId  String?
  driver    User?    @relation("Driver", fields: [driverId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  trajets   Trajet[]

  @@unique([tenantId, number])
}

model Trajet {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  busId       String
  bus         Bus      @relation(fields: [busId], references: [id])
  driverId    String?
  driver      User?    @relation("TrajetDriver", fields: [driverId], references: [id])
  origin      String
  destination String
  date        DateTime
  time        String
  price       Int
  zone        String?
  status      String   @default("scheduled")
  createdAt   DateTime @default(now())
  billets     Billet[]
}

// TrajetStatus values: scheduled, boarding, departed, arrived, cancelled

model Billet {
  id           String   @id @default(cuid())
  trajetId     String
  trajet       Trajet   @relation(fields: [trajetId], references: [id])
  clientId     String
  client       User     @relation("Client", fields: [clientId], references: [id])
  seatNumber   Int
  ticketNumber String   @unique
  qrCode       String   @unique
  status       String   @default("sold")
  createdAt    DateTime @default(now())
}

// BilletStatus values: sold, boarded, absent, cancelled

model VoiceConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  introText       String
  audioUrl        String?
  language        String   @default("fr-FR")
  announceT15     Boolean  @default(true)
  announceT5      Boolean  @default(true)
  announceT2      Boolean  @default(true)
  announceDelay   Boolean  @default(true)
  announceArrival Boolean  @default(true)
  createdAt       DateTime @default(now())
}

// SubscriptionStatus values: active, trial, expired, cancelled
model Subscription {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  plan         String   @default("starter")
  status       String   @default("active")
  startDate    DateTime @default(now())
  endDate      DateTime
  pricePerBus  Int      @default(20000)
  busCount     Int      @default(0)
  totalAmount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invoices     Invoice[]
}

// InvoiceStatus values: paid, pending, failed, overdue, cancelled
model Invoice {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  invoiceNumber   String?   @unique // ex: INV-2026-001
  invoiceDate     DateTime  @default(now())
  dueDate         DateTime

  // Détails
  periodStart     DateTime?
  periodEnd       DateTime?
  numberOfBuses   Int       @default(0)
  pricePerBus     Int       @default(20000)
  subtotal        Int       @default(0)
  tax             Int       @default(0)
  total           Int       @default(0)

  // Status
  status          String    @default("pending") // pending, paid, overdue, cancelled
  paidAt          DateTime?
  paymentMethod   String?

  // PDF
  pdfUrl          String?

  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([invoiceDate])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  action    String
  message   String
  userId    String?
  tenantId  String?
  metadata  String?
  createdAt DateTime @default(now())
}

// NotificationEvent values: boarding_reminder, delay_alert, arrival_notice, payment_reminder, welcome, subscription_expiry
model NotificationTemplate {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  type      String   @default("email")
  event     String
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  id              String    @id @default("global")

  // SEO Global
  siteName        String    @default("Bus Go")
  siteDescription String    @default("SaaS de gestion d'embarquement pour compagnies de bus")
  siteKeywords    String?
  ogImage         String?
  favicon         String?

  // Branding
  logoUrl         String?
  primaryColor    String    @default("#7C3AED")
  secondaryColor  String    @default("#F43F5E")

  // Contact
  supportEmail    String    @default("support@busgo.sn")
  supportPhone    String    @default("+221 33 XXX XX XX")
  supportWhatsApp String    @default("+221 77 XXX XX XX")
  address         String?

  // Pricing
  pricePerBus     Int       @default(20000)
  trialDays       Int       @default(14)

  // Features
  smsEnabled      Boolean   @default(false)
  whatsappEnabled Boolean   @default(true)
  ttsEnabled      Boolean   @default(true)

  updatedAt       DateTime  @updatedAt
}

// AuditLog — tracks all critical superadmin actions
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // tenant.create, tenant.suspend, invoice.pay, config.update, etc.
  entityType  String?  // Tenant, Invoice, SystemConfig
  entityId    String?
  oldValues   String?  // JSON string of previous values
  newValues   String?  // JSON string of new values
  tenantId    String?  // affected tenant
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entityType])
  @@index([tenantId])
  @@index([createdAt])

  @@index([userId])
}